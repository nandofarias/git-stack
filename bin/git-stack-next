#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Usage: git next"
  echo "Switch to the child branch (one step up the stack)."
  echo "If multiple children exist, opens fzf to pick one."
  exit 0
fi

current=$(git rev-parse --abbrev-ref HEAD)
current_sha=$(git rev-parse HEAD)

# Find all branches that forked from current and have their own commits
descendants=()
while IFS= read -r line; do
  sha="${line%% *}"
  name="${line#* }"
  [[ "$name" == "develop" || "$name" == "$current" ]] && continue
  mb=$(git merge-base "$current_sha" "$sha" 2>/dev/null) || continue
  # Skip if branch tip IS the merge-base (no unique commits)
  [[ "$mb" == "$sha" ]] && continue
  # Count unique commits on this branch (beyond fork point)
  unique=$(git rev-list --count "$mb..$sha" 2>/dev/null) || continue
  [[ "$unique" -eq 0 ]] && continue
  descendants+=("$unique:$name")
done < <(git for-each-ref --format='%(objectname) %(refname:short)' refs/heads/)

if [[ ${#descendants[@]} -eq 0 ]]; then
  echo "No child branch found (already at top of stack)."
  exit 1
fi

# Sort by number of unique commits (fewest first = closest to base)
IFS=$'\n' sorted=($(printf '%s\n' "${descendants[@]}" | sort -t: -k1 -n)); unset IFS

# A direct child is one where no other descendant sits between it and current.
direct=()
for entry in "${sorted[@]}"; do
  name="${entry#*:}"
  is_direct=true
  for prev_name in "${direct[@]}"; do
    if git merge-base --is-ancestor "$prev_name" "$name" 2>/dev/null; then
      is_direct=false
      break
    fi
  done
  $is_direct && direct+=("$name")
done

if [[ ${#direct[@]} -eq 1 ]]; then
  git switch "${direct[0]}"
elif [[ ${#direct[@]} -gt 1 ]]; then
  if ! command -v fzf &>/dev/null; then
    echo "Multiple child branches:"
    for b in "${direct[@]}"; do
      echo "  $b"
    done
    echo "Install fzf for interactive selection, or: git switch <branch>"
    exit 1
  fi

  selected=$(printf '%s\n' "${direct[@]}" | fzf --prompt="next branch> " --header="Pick a stack to enter" --no-multi)
  if [[ -n "$selected" ]]; then
    git switch "$selected"
  fi
fi
